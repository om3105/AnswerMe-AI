# ==============================
# AnswerMe AI — Environment Variables
# ==============================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file — only .env.example is tracked by Git.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up --build

# ──────────────────────────────
# Application
# ──────────────────────────────
APP_NAME=AnswerMe AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ──────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost"]

# ──────────────────────────────
# Frontend (React + Vite)
# ──────────────────────────────
VITE_API_URL=http://localhost/api/v1
FRONTEND_PORT=5173

# ──────────────────────────────
# PostgreSQL
# ──────────────────────────────
POSTGRES_USER=answerme
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=answerme_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://answerme:change_me_in_production@postgres:5432/answerme_db

# ──────────────────────────────
# Redis
# ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────
# JWT Authentication
# ──────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────
# Nginx
# ──────────────────────────────
NGINX_PORT=80
