# ──────────────────────────────
# AnswerMe AI Backend — Environment Variables
# ──────────────────────────────
# Copy to .env: cp .env.example .env

# Application
APP_NAME=AnswerMe AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://answerme:change_me_in_production@postgres:5432/answerme_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost"]
