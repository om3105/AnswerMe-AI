# ──────────────────────────────
# AnswerMe AI Frontend — Environment Variables
# ──────────────────────────────
# Copy to .env.local: cp .env.example .env.local
#
# Vite exposes env vars prefixed with VITE_ to client-side code.
# (Next.js uses NEXT_PUBLIC_ — we use Vite, so it's VITE_)

# API URL (must be prefixed with VITE_ to be available in browser)
VITE_API_URL=http://localhost/api/v1
